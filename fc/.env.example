# ============================================
# API Gateway 环境变量配置
# 复制此文件为 .env 并填入你的密钥
# ============================================

# Gemini (Google)
GEMINI_API_KEY=你的Gemini密钥
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta

# Seedance (即梦)
SEEDANCE_API_KEY=你的Seedance密钥
SEEDANCE_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3

# Vidu
VIDU_API_KEY=你的Vidu密钥
VIDU_ENDPOINT=https://api.vidu.cn/ent/v2

# Kling (可灵)
KLING_API_KEY=你的可灵密钥
KLING_ENDPOINT=https://api.klingai.com

# Zhanhu (站狐)
ZHANHU_API_KEY=你的站狐密钥
ZHANHU_ENDPOINT=https://api.zhanhu.ai/v1
