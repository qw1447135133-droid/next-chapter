{
  "name": "next-chapter-gemini-cli",
  "displayName": "Gemini Code Page",
  "description": "Run the local Gemini CLI inside a dedicated VS Code page with a PTY-backed embedded terminal.",
  "version": "0.0.1",
  "publisher": "next-chapter-local",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/qw1447135133-droid/next-chapter.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:geminiCli.panel",
    "onCommand:geminiCli.startSession",
    "onCommand:geminiCli.newSession",
    "onCommand:geminiCli.refreshStatus",
    "onCommand:geminiCli.openSettings"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "geminiCli",
          "title": "Gemini",
          "icon": "media/gemini-activity.svg"
        }
      ]
    },
    "views": {
      "geminiCli": [
        {
          "id": "geminiCli.panel",
          "name": "Gemini",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "geminiCli.startSession",
        "title": "Gemini: Open Page",
        "icon": {
          "light": "media/play-light.svg",
          "dark": "media/play-dark.svg"
        }
      },
      {
        "command": "geminiCli.newSession",
        "title": "Gemini: New Page Session",
        "icon": {
          "light": "media/plus-light.svg",
          "dark": "media/plus-dark.svg"
        }
      },
      {
        "command": "geminiCli.refreshStatus",
        "title": "Gemini: Refresh CLI Status",
        "icon": {
          "light": "media/refresh-light.svg",
          "dark": "media/refresh-dark.svg"
        }
      },
      {
        "command": "geminiCli.openSettings",
        "title": "Gemini: Open Extension Settings",
        "icon": {
          "light": "media/settings-light.svg",
          "dark": "media/settings-dark.svg"
        }
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "geminiCli.startSession",
          "when": "view == geminiCli.panel",
          "group": "navigation"
        },
        {
          "command": "geminiCli.newSession",
          "when": "view == geminiCli.panel",
          "group": "navigation@1"
        },
        {
          "command": "geminiCli.refreshStatus",
          "when": "view == geminiCli.panel",
          "group": "navigation@2"
        }
      ],
      "editor/title": [
        {
          "command": "geminiCli.startSession",
          "group": "navigation@9"
        }
      ]
    },
    "configuration": {
      "title": "Gemini Code Page",
      "properties": {
        "geminiCli.command": {
          "type": "string",
          "default": "gemini",
          "description": "Command or full path used to launch Gemini."
        },
        "geminiCli.shellPath": {
          "type": "string",
          "default": "",
          "description": "Optional shell path. Leave empty to use powershell.exe on Windows or your VS Code default shell elsewhere."
        },
        "geminiCli.terminalName": {
          "type": "string",
          "default": "Gemini CLI",
          "description": "Reserved for future expansion."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0"
  }
}
